# ─────────────────────────────────────────────────────────────
#  Stratum Backend — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to Git.
# ─────────────────────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS — your Vercel domain in production)
FRONTEND_URL=http://localhost:5173

# GitHub OAuth App (created at github.com/settings/developers)
GITHUB_CLIENT_ID=Ov23likMYS1a1HqvDwiM
GITHUB_CLIENT_SECRET=aafea4f1a14b75f93db897d6cd7149ed2470056d

# GitHub Personal Access Token (classic, repo scope)
# Generate at: github.com/settings/tokens
GITHUB_PAT=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

# GitHub repo where submissions are stored
GITHUB_REPO_OWNER=Infometry-Infofiscus
GITHUB_REPO_NAME=stratum-data
GITHUB_DATA_PATH=data/submissions

# Admin — GitHub username with approve/reject access
ADMIN_GITHUB_LOGIN=Infometry-Infofiscus