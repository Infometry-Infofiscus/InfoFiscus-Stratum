# GitHub repository (public vars — embedded in static export)
NEXT_PUBLIC_GITHUB_OWNER=infometry-infofiscus
NEXT_PUBLIC_GITHUB_REPO=InfoFiscus-Stratum
NEXT_PUBLIC_GITHUB_BRANCH=main
NEXT_PUBLIC_GITHUB_SUBMIT_PROXY=https://text2sql-github-submit.infometry-github-submit.workers.dev

# Path prefix for new files (optional; default submissions/pending)
# NEXT_PUBLIC_GITHUB_PENDING_PREFIX=submissions/pending

# A) Direct browser → GitHub (token appears in deployed JS — use fine-grained PAT + rotation)
# NEXT_PUBLIC_GITHUB_TOKEN=github_pat_xxxxxxxx

# B) Recommended: proxy URL (see /proxy/cloudflare-worker.js)
# NEXT_PUBLIC_GITHUB_SUBMIT_PROXY=https://your-worker.workers.dev
